<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhihui.system.mapper.MajorMapper">

    <resultMap id="BaseResultMap" type="com.zhihui.system.entity.Major">
        <id column="id" property="id"/>
        <result column="college_id" property="collegeId"/>
        <result column="major_code" property="majorCode"/>
        <result column="major_name" property="majorName"/>
        <result column="major_en_name" property="majorEnName"/>
        <result column="degree_type" property="degreeType"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据学院ID查询专业列表 -->
    <select id="selectByCollegeId" resultMap="BaseResultMap">
        SELECT * FROM major WHERE college_id = #{collegeId} AND status = 1
        ORDER BY sort_order
    </select>

</mapper>
