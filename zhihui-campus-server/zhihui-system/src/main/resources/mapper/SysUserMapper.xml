<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhihui.system.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.zhihui.system.entity.SysUser">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="user_type" property="userType"/>
        <result column="college_id" property="collegeId"/>
        <result column="major_id" property="majorId"/>
        <result column="class_name" property="className"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="avatar" property="avatar"/>
        <result column="sex" property="sex"/>
        <result column="status" property="status"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="remark" property="remark"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据角色ID查询用户列表 -->
    <select id="selectUsersByRoleId" resultMap="BaseResultMap">
        SELECT u.* FROM sys_user u
        LEFT JOIN sys_user_role ur ON u.id = ur.user_id
        WHERE ur.role_id = #{roleId} AND u.deleted = 0
    </select>

    <!-- 根据学院ID查询用户列表 -->
    <select id="selectUsersByCollegeId" resultMap="BaseResultMap">
        SELECT * FROM sys_user WHERE college_id = #{collegeId} AND deleted = 0
    </select>

</mapper>
