<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhihui.life.mapper.CardTransactionMapper">

    <resultMap id="BaseResultMap" type="com.zhihui.life.entity.CardTransaction">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="card_no" property="cardNo"/>
        <result column="amount" property="amount"/>
        <result column="balance" property="balance"/>
        <result column="transaction_type" property="transactionType"/>
        <result column="merchant_name" property="merchantName"/>
        <result column="merchant_no" property="merchantNo"/>
        <result column="transaction_time" property="transactionTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 查询用户余额 -->
    <select id="selectBalance" resultType="java.math.BigDecimal">
        SELECT balance FROM life_card_transaction
        WHERE user_id = #{userId}
        ORDER BY transaction_time DESC
        LIMIT 1
    </select>

</mapper>
